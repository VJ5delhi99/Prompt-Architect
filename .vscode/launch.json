{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Prompt Architect Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "env": {
        "NODE_OPTIONS": "--no-deprecation"
      },
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ]
    }
  ]
}
